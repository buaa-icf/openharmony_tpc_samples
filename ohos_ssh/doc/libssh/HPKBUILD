pkgname=libssh
pkgver=0.11.1
pkgrel=0
pkgdesc="libssh is a multiplatform C library implementing the SSHv2 protocol on client and server side. With libssh, you can remotely execute programs, transfer files, use a secure and transparent tunnel, manage public keys and much more ..."
url="https://www.libssh.org/"
archs=("armeabi-v7a" "arm64-v8a")
license=("LGPL-2.1" "BSDv2")
depends=("openssl-3.5.4")
makedepends=()

source="https://www.libssh.org/files/${pkgver:0:4}/$pkgname-$pkgver.tar.xz"

autounpack=true
downloadpackage=true
patchflag=true

builddir=$pkgname-${pkgver}
packagename=$builddir.tar.xz

source envset.sh

prepare() {
    if $patchflag
    then
        cd $builddir
        patch -p1 < $PKGBUILD_ROOT/libssh_oh_pkg.patch > $publicbuildlog 2>&1
        # patch只需要打一次,关闭打patch
        patchflag=false
        cd $OLDPWD
    fi
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    
    # 设置环境变量（包括STRIP）
    if [ $ARCH == "armeabi-v7a" ]; then
        setarm32ENV
    elif [ $ARCH == "arm64-v8a" ]; then
        setarm64ENV
    else
        echo "${ARCH} not support"
        return -1
    fi
    
    # -DUNIT_TESTING=ON # depends on cmocka
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -DCLIENT_TESTING=ON \
    -DSERVER_TESTING=ON -DWITH_EXAMPLES=ON \
    -DCMAKE_INSTALL_PREFIX="$LYCIUM_ROOT/usr/$pkgname/$ARCH" \
    -L -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir/$ARCH-build
    local installdir="$LYCIUM_ROOT/usr/$pkgname/$ARCH"

    make install STRIP="" >> $buildlog 2>&1

    # 复制带符号的so文件为.debug版本（用于崩溃调试）
    if [ -f "$installdir/lib/libssh.so.4" ]; then
        echo "Creating debug version: libssh.so.4.debug" >> $buildlog
        cp "$installdir/lib/libssh.so.4" "$installdir/lib/libssh.so.4.debug"
    fi
    
    # 剥离正式版本的符号（减小体积）
    if [ -f "$installdir/lib/libssh.so.4" ]; then
        echo "Stripping release version: libssh.so.4" >> $buildlog
        ${STRIP} "$installdir/lib/libssh.so.4" >> $buildlog 2>&1
    fi

    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
