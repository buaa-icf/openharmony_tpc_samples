import { describe, beforeAll, beforeEach, afterEach, afterAll, it, expect } from '@ohos/hypium'

import AhoCorasick from 'ahocorasick'

export default function ahocorasickTest() {
  var testCases = [
    {
      keywords: ['hero', 'heroic'],
      text: 'hero',
      expected: [
        [3, ['hero']]
      ]
    },
    {
      keywords: ['hero', 'heroic', 'heroism'],
      text: 'the hero performed a heroic act of heroism',
      expected: [
      // "hero" is a substring of "heroic" and "heroism", so we should find it 3 times
        [7, ['hero']],
        [24, ['hero']],
        [26, ['heroic']],
        [38, ['hero']],
        [41, ['heroism']]
      ]
    },
    {
      keywords: ['keyword1', 'keyword2', 'etc'],
      text: 'should find keyword1 at position 19 and keyword2 at position 30.',
      expected: [
        [19, ['keyword1']],
        [47, ['keyword2']]
      ]
    },
    {
      keywords: ['he', 'she', 'his', 'hers'],
      text: 'she was expecting his visit',
      expected: [
        [2, ['he', 'she']],
        [20, ['his']]
      ]
    },
    {
      keywords: ['├πp?', '├σ├λ├ι'],
      text: '├σ├λ├ιqwfw├σ├λ├σeqfw├σ├λ├ιqef ├ι├σ├πp?ά║Δ wqqryht cp?',
      expected: [
        [2, ['├σ├λ├ι']],
        [16, ['├σ├λ├ι']],
        [25, ['├πp?']]
      ]
    },
    {
      keywords: ['**', '666', 'his', 'n', '\\', '\n'],
      text: '\n & 666 ==! \n',
      expected: [
        [0, ['\n']],
        // [20, ['his']]
        [6, ['666']],
        [12, ['\n']]
      ]
    },
    {
      keywords: ['╨ν╨╡╨┤╨╡╤Α╨░╨╗╤Ν╨╜╨╛╨╣', '╨╜╨╛╨╣', 'idea'],
      text: '! ╨ν╨╡╨┤╨╡╤Α╨░╨╗╤Ν╨╜╨╛╨╣ I have no idea what this means.',
      expected: [
        [12, ['╨ν╨╡╨┤╨╡╤Α╨░╨╗╤Ν╨╜╨╛╨╣', '╨╜╨╛╨╣']],
        [27, ['idea']]
      ]
    },
    {
      keywords: ['.com.au','.com'],
      text: 'www.yahoo.com',
      expected: [
        [12, ['.com']]
      ]
    }
  ].map(function(ts) {
    ts.expected = ts.expected.map(function(expected) {
      if(typeof  expected[1] == "object" && Array.isArray(expected[1])) {
        expected[1] = expected[1].sort();
      }
      return expected;
    });
    return ts;
  });

  var _s = AhoCorasick.prototype.search;
  AhoCorasick.prototype.search = function(string) {
    var results = _s.call(this, string).map(function(result) {
      if(typeof  result[1] == "object" && Array.isArray(result[1])){
        result[1] = result[1].sort();
      }
      return result;
    });
    return results;
  };

  describe('AhocorasickTest', function () {
    it('AhoCorasick_Test', 0, function () {
      testCases.forEach(function(ts) {
        var keys = ts.keywords;
        var text = ts.text;
        var expected = ts.expected;
        it('should test: ' + keys.join(', '),0, function() {
          var aho = new AhoCorasick(keys);
          expect(expected).assertDeepEquals(aho.search(text));
        });
      });
    })

    it('AhoCorasick_emoji', 0, function () {
      var aho = new AhoCorasick(['bla', 'ΏθαΒ', 'ΏθαΑ', 'ΏθαΑΏθαΒΏθαΑ']);
      expect([
        [5, ['ΏθαΒ']],
        [9, ['bla']],
        [12, ['ΏθαΑ']],
        [17, ['ΏθαΑ']],
        [22, ['ΏθαΑ']],
        [24, ['ΏθαΒ']],
        [26, ['ΏθαΑ', 'ΏθαΑΏθαΒΏθαΑ']],
      ]).assertDeepEquals(aho.search('Bla ΏθαΒ bla ΏθαΑ 1 ΏθαΑ - ΏθαΑΏθαΒΏθαΑ-'));
    })

    it('AhoCorasick_emoji2', 0, function () {
      var aho = new AhoCorasick(['bla', 'ΏθαΒ', 'ΏθαΑ', '┬░έΨκ┬░', 'w', 'έΦ╗έΦΒέΦ╗']);
      expect([
        [7, ['┬░έΨκ┬░']],
        [14, ['έΦ╗έΦΒέΦ╗']],
      ]).assertDeepEquals(aho.search("-  (έΧψ┬░έΨκ┬░Ύ╝ΚέΧψΎ╕╡ έΦ╗έΦΒέΦ╗ "));
    })
  })
}