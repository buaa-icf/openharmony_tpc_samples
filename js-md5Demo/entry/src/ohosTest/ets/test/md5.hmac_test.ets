function runTestSuite(name: keyof HmacTestSuite) {
  describe(`HMAC-MD5 ${name}测试套件`, () => {
    // 使用类型安全的方式访问测试套件
    const suite: TestVector[] = (() => {
      switch(name) {
        case 'testVectors': return testCases.testVectors;
        case 'utf8': return testCases.utf8;
        case 'bufferCases': return testCases.bufferCases;
        default: throw new Error('Invalid test suite name');
      }
    })();

    suite.forEach((testCase, index) => {
      console.info('test:'+testCase.key.toString()+index)
      it(`测试用例#${index + 1}`, 0, () => {
        const result = md5.hmac(testCase.key, testCase.message!);
        expect(result).assertEqual(testCase.expected);
      });
    });

    if (name === 'bufferCases') {
      it('空Uint8Array测试', 0, () => {
        const result = md5.hmac(new Uint8Array(0), 'Hi There');
        expect(result).assertEqual('72c33c78cac0b7a581ac263a344ed01d');
      });
      it('空ArrayBuffer测试', 0, () => {
        const bufferKey = new Uint8Array(new ArrayBuffer(0));
        const result = md5.hmac(bufferKey, 'Hi There');
        expect(result).assertEqual('72c33c78cac0b7a581ac263a344ed01d');
      });
    }
  });
}

export default function hmacTestMain() {
  runTestSuite('testVectors');
  runTestSuite('utf8');
  runTestSuite('bufferCases');
}














