import { describe, it, expect } from '@ohos/hypium';
import { md5 } from 'js-md5';

// 新增精确类型声明
interface TestVector {
  expected: string;
  key: Uint8Array | ArrayBuffer | string;
  message?: Uint8Array | ArrayBuffer | string;
}

interface LengthObject {
  length: number;
}

interface HmacTestSuite {
  testVectors: TestVector[];
  utf8: TestVector[];
  bufferCases: TestVector[];
}

// 修改后的精确类型声明
type InvalidInputType =
  | string
  | Uint8Array
  | ArrayBuffer
  | LengthObject
  | number
  | boolean
  | null
  | undefined
  | Function;


class HexConverter {
  static toHexString(array: Uint8Array): string {
    let hex = '';
    for (let i = 0; i < array.length; ++i) {
      const c = array[i].toString(16).padStart(2, '0');
      hex += c;
    }
    return hex;
  }
}

