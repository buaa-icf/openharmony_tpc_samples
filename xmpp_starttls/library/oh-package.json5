    "@ohos/xmpp_middleware": "^1.0.0",
    "@ohos/xmpp_stream_features": "^1.0.0",
    "@types/koa-compose": "^3.2.8",
    "@ohos/xmpp_connection_tcp": "^1.0.1"
  },
  "devDependencies": {},
  "dynamicDependencies": {}
