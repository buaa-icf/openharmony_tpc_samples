@Entry
@Component
struct User {
  account: string = ''
  password: string = ''
  ip: string = ''
  email: string = ''
  dbStorageController = new IndexedDBStorageController()
  @State message: string = ''
  userId: string | undefined = ''

  aboutToAppear(): void {
    Parse.initialize('wahaha', '123123'); // дҪҝз”ЁдҪ зҡ„ JavaScript Key
    Parse.serverURL = 'http://192.168.0.2:1337/parse';
  }

  handleParseError(err: ESObject) {
    switch (err.code) {
      case Parse.Error.INVALID_SESSION_TOKEN:
        Parse.User.logOut()
        break;
    }
  }

  build() {
    Scroll() {
      Column({ space: 20 }) {
        TextInput({ placeholder: 'иҜ·иҫ“е…ҘиҙҰеҸ·', text: 'admin' })
          .borderRadius(4)
          .onChange((val) => {
            this.account = val
          })

        TextInput({ placeholder: 'иҜ·иҫ“е…ҘеҜҶз Ғ', text: '123123' })
          .borderRadius(4)
          .onChange((val) => {
            this.password = val
          })

        TextInput({ placeholder: 'иҜ·иҫ“е…ҘйӮ®з®ұ', text: 'email@example.com' })
          .borderRadius(4)
          .onChange((val) => {
            this.email = val
          })

        TextInput({ placeholder: 'иҜ·иҫ“е…ҘIP', text: '192.168.0.2' })
          .borderRadius(4)
          .onChange((val) => {
            this.ip = val
          })

        Button('жіЁеҶҢ')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''
            const user = new Parse.User();
            user.set('username', this.account);
            user.set('password', this.password);
            user.set('email', this.email);
            try {
              await user.signUp();
              this.message = 'жіЁеҶҢжҲҗеҠҹ:' + JSON.stringify(user)
            } catch (e) {
              this.message = 'жіЁеҶҢеӨұиҙҘ:' + JSON.stringify(e)
            }
          })

        Button('зҷ»еҪ•')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''
            try {
              const loggedInUser = await Parse.User.logIn(this.account, this.password, { usePost: false });
              this.userId = loggedInUser.id
              this.message = 'зҷ»еҪ•жҲҗеҠҹ:' + loggedInUser.id
            } catch (e) {
              this.message = 'зҷ»еҪ•еӨұиҙҘ:' + JSON.stringify(e)
            }
          })

        Button('иҺ·еҸ–еҪ“еүҚз”ЁжҲ·')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''
            let currentUser: ESObject = null
            try {
              currentUser = Parse.User.current();
              this.message = 'иҺ·еҸ–еҪ“еүҚз”ЁжҲ·жҲҗеҠҹ:' + currentUser?.id + '\r\n\r\n'
            } catch (e) {
              this.message = 'иҺ·еҸ–еҪ“еүҚз”ЁжҲ·еӨұиҙҘ:' + JSON.stringify(e) + '\r\n\r\n'
            }

            currentUser.set('email', 'updated@example.com');
            try {
              await currentUser.save();
              this.message += 'з”ЁжҲ·жӣҙж–°жҲҗеҠҹ : ' + JSON.stringify(currentUser) + '\r\n\r\n'
            } catch (e) {
              this.message += 'з”ЁжҲ·жӣҙж–°еӨұиҙҘ : ' + JSON.stringify(e) + '\r\n\r\n'
            }
          })

        Button('йҖҖеҮәзҷ»йҷҶ')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''
            try {
              await Parse.User.logOut();
              this.message = 'йҖҖеҮәзҷ»йҷҶжҲҗеҠҹ'
            } catch (e) {
              this.message = 'йҖҖеҮәзҷ»йҷҶеӨұиҙҘ:' + JSON.stringify(e)
            }
          })

        Button('Encrypting Current User')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''
            //д»…еңЁжөҸи§ҲеҷЁзҺҜеўғдёӢз”ҹж•Ҳ
            Parse.enableEncryptedUser();
            Parse.secret = '123123';
            this.message = 'еҠ еҜҶеҪ“еүҚз”ЁжҲ·жҲҗеҠҹ' + JSON.stringify(Parse.isEncryptedUserEnabled())
          })


        Button('Security For Other Objects')
          .borderRadius(4)
          .type(ButtonType.Normal)
          .width('100%')
          .onClick(async () => {
            this.message = ''

            try {
              const Note: ESObject = Parse.Object.extend("Note");
              const privateNote: ESObject = new Note();
              privateNote.set("content", "This note is private!");
              privateNote.setACL(new Parse.ACL(Parse.User.current()));
              privateNote.save();
              const query = new Parse.Query(Note);
              query.equalTo("objectId", privateNote.id);
              await query.first();
              this.message = 'еҠ еҜҶеҜ№иұЎжҲҗеҠҹ'
            } catch (e) {
              this.message = 'еҠ еҜҶеҜ№иұЎеӨұиҙҘпјҡ'+JSON.stringify(e)
            }
          })

        Text(this.message)
          .fontSize(16)
      }
      .margin(10)
    }
    .width('100%')
    .height('100%')
  }
}