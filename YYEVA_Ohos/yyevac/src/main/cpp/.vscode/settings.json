    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "clang-format.assumeFilename": "/root/.clang-format",
    "clang-format.executable": "/usr/bin/clang-format",
    "clang-format.fallbackStyle": "LLVM",
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.quickSuggestions": {
        "strings": "on"
