 * еҢ…еҗ«и§Ҷйў‘жЁЎејҸгҖҒй”ҷиҜҜзұ»еһӢгҖҒй”ҷиҜҜж¶ҲжҒҜзӯүеёёйҮҸ
 */
export class EvaConstant {
  static readonly TAG = 'EvaAnimPlayer'

  // и§Ҷйў‘жЁЎејҸ
  static readonly VIDEO_MODE_NORMAL_MP4_NONE = -2  // ж— жЈҖжөӢзҠ¶жҖҒ
  static readonly VIDEO_MODE_NORMAL_MP4 = -1        // жӯЈеёёmp4
  // и§Ҷйў‘еҜ№йҪҗж–№ејҸ (е…је®№иҖҒзүҲжң¬и§Ҷйў‘жЁЎејҸ)
  static readonly VIDEO_MODE_SPLIT_HORIZONTAL = 1              // и§Ҷйў‘е·ҰеҸіеҜ№йҪҗпјҲalphaе·Ұ\rgbеҸіпјү
  static readonly VIDEO_MODE_SPLIT_VERTICAL = 2                // и§Ҷйў‘дёҠдёӢеҜ№йҪҗпјҲalphaдёҠ\rgbдёӢпјү
  static readonly VIDEO_MODE_SPLIT_HORIZONTAL_REVERSE = 3      // и§Ҷйў‘е·ҰеҸіеҜ№йҪҗпјҲrgbе·Ұ\alphaеҸіпјү
  static readonly VIDEO_MODE_SPLIT_VERTICAL_REVERSE = 4        // и§Ҷйў‘дёҠдёӢеҜ№йҪҗпјҲrgbдёҠ\alphaдёӢпјү
  static readonly YYEVAColorRegion_AlphaMP4_alphaHalfRightTop = 5  // и§Ҷйў‘дёҠдёӢеҜ№йҪҗпјҲrgbдёҠ\alphaдёӢпјү1/4 elpha

  // зҠ¶жҖҒз Ғ
  static readonly OK = 0  // жҲҗеҠҹ

  // й”ҷиҜҜзұ»еһӢ
  static readonly REPORT_ERROR_TYPE_EXTRACTOR_EXC = 10001  // MediaExtractor exception
  static readonly REPORT_ERROR_TYPE_DECODE_EXC = 10002     // MediaCodec exception
  static readonly REPORT_ERROR_TYPE_CREATE_THREAD = 10003  // зәҝзЁӢеҲӣе»әеӨұиҙҘ
  static readonly REPORT_ERROR_TYPE_CREATE_RENDER = 10004  // renderеҲӣе»әеӨұиҙҘ
  static readonly REPORT_ERROR_TYPE_PARSE_CONFIG = 10005   // й…ҚзҪ®и§ЈжһҗеӨұиҙҘ
  static readonly REPORT_ERROR_TYPE_CONFIG_PLUGIN_MIX = 10006  // иһҚеҗҲеҠЁз”»иө„жәҗиҺ·еҸ–еӨұиҙҘ
  static readonly REPORT_ERROR_TYPE_FILE_ERROR = 10007     // ж–Үд»¶ж— жі•иҜ»еҸ–
  static readonly REPORT_ERROR_TYPE_HEVC_NOT_SUPPORT = 10008  // дёҚж”ҜжҢҒh265

  // й”ҷиҜҜж¶ҲжҒҜ
  static readonly ERROR_MSG_EXTRACTOR_EXC = '0x1 MediaExtractor exception'  // MediaExtractor exception
  static readonly ERROR_MSG_DECODE_EXC = '0x2 MediaCodec exception'         // MediaCodec exception
  static readonly ERROR_MSG_CREATE_THREAD = '0x3 thread create fail'        // зәҝзЁӢеҲӣе»әеӨұиҙҘ
  static readonly ERROR_MSG_CREATE_RENDER = '0x4 render create fail'         // renderеҲӣе»әеӨұиҙҘ
  static readonly ERROR_MSG_PARSE_CONFIG = '0x5 parse config fail'          // й…ҚзҪ®и§ЈжһҗеӨұиҙҘ
  static readonly ERROR_MSG_CONFIG_PLUGIN_MIX = '0x6 yyeva fail'            // иһҚеҗҲеҠЁз”»иө„жәҗиҺ·еҸ–еӨұиҙҘ
  static readonly ERROR_MSG_FILE_ERROR = '0x7 file can\'t read'            // ж–Үд»¶ж— жі•иҜ»еҸ–
  static readonly ERROR_MSG_HEVC_NOT_SUPPORT = '0x8 hevc not support'      // дёҚж”ҜжҢҒh265

  /**
   * иҺ·еҸ–й”ҷиҜҜж¶ҲжҒҜ
   * @param errorType й”ҷиҜҜзұ»еһӢ
   * @param errorMsg йўқеӨ–й”ҷиҜҜж¶ҲжҒҜ
   * @return е®Ңж•ҙзҡ„й”ҷиҜҜж¶ҲжҒҜ
   */
  static getErrorMsg(errorType: number, errorMsg?: string | null): string {
    let baseMsg: string
    switch (errorType) {
      case EvaConstant.REPORT_ERROR_TYPE_EXTRACTOR_EXC:
        baseMsg = EvaConstant.ERROR_MSG_EXTRACTOR_EXC
        break
      case EvaConstant.REPORT_ERROR_TYPE_DECODE_EXC:
        baseMsg = EvaConstant.ERROR_MSG_DECODE_EXC
        break
      case EvaConstant.REPORT_ERROR_TYPE_CREATE_THREAD:
        baseMsg = EvaConstant.ERROR_MSG_CREATE_THREAD
        break
      case EvaConstant.REPORT_ERROR_TYPE_CREATE_RENDER:
        baseMsg = EvaConstant.ERROR_MSG_CREATE_RENDER
        break
      case EvaConstant.REPORT_ERROR_TYPE_PARSE_CONFIG:
        baseMsg = EvaConstant.ERROR_MSG_PARSE_CONFIG
        break
      case EvaConstant.REPORT_ERROR_TYPE_CONFIG_PLUGIN_MIX:
        baseMsg = EvaConstant.ERROR_MSG_CONFIG_PLUGIN_MIX
        break
      case EvaConstant.REPORT_ERROR_TYPE_FILE_ERROR:
        baseMsg = EvaConstant.ERROR_MSG_FILE_ERROR
        break
      case EvaConstant.REPORT_ERROR_TYPE_HEVC_NOT_SUPPORT:
        baseMsg = EvaConstant.ERROR_MSG_HEVC_NOT_SUPPORT
        break
      default:
        baseMsg = 'unknown'
        break
    }
    return `${baseMsg} ${errorMsg || ''}`
  }

  // жіЁеҶҢEvaAnimж’ӯж”ҫж—¶зҡ„зӣёе…ідәӢд»¶пјҲеҜ№еә”AndroidдёӯIEvaAnimListenerдёӯзҡ„жҺҘеҸЈпјү
  static readonly EVENT_ID_ON_VIDEO_CONFIG_READY = 'onVideoConfigReady';
  static readonly EVENT_ID_ON_VIDEO_START = 'onVideoStart';
  static readonly EVENT_ID_ON_VIDEO_RESTART = 'onVideoRestart';
  static readonly EVENT_ID_ON_VIDEO_RENDER = 'onVideoRender';
  static readonly EVENT_ID_ON_VIDEO_COMPLETE = 'onVideoComplete';
  static readonly EVENT_ID_ON_VIDEO_DESTROY = 'onVideoDestroy';
  static readonly EVENT_ID_ON_FAILED = 'onFailed';
  // е°әеҜёеҸ‘з”ҹеҸҳеҢ–
  static readonly EVENT_ID_SIZE_CHANGED = 'sieze_changed';


  //ж”ҜжҢҒзҡ„и§Ҷйў‘зј–з Ғзұ»еһӢ
  static readonly MIME_HEVC: string = "video/hevc";
}