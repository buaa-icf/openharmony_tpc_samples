<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <oatconfig>
        <filefilterlist>
            <filefilter
                desc="Filters for compatibility，license header policies"
                name="copyrightPolicyFilter">
                <filteritem
                    desc="hvigor配置文件，DevEco Studio自动生成，不手动修改"
                    name="*.json5"
                    type="filename"/>
                <filteritem
                    desc="hvigor配置文件，DevEco Studio自动生成，不手动修改"
                    name="*.json5.ftl"
                    type="filename"/>
            </filefilter>
            <filefilter
                desc="Filters for compatibility，license header policies"
                name="defaultPolicyFilter">
                <filteritem
                    desc="hvigor配置文件，DevEco Studio自动生成，不手动修改"
                    name="*.json5"
                    type="filename"/>
                <filteritem
                    desc="hvigor配置文件，DevEco Studio自动生成，不手动修改"
                    name="*.json5.ftl"
                    type="filename"/>
            </filefilter>
        </filefilterlist>
        <policylist>
            <policy
                desc=""
                name="projectPolicy">
                <policyitem
                    desc="该协议是原组件下的协议，无需修改。"
                    filefilter="defaultPolicyFilter"
                    group="defaultGroup"
                    name="MIT"
                    path=".*"
                    type="license"/>
            </policy>
        </policylist>
    </oatconfig>
</configuration>