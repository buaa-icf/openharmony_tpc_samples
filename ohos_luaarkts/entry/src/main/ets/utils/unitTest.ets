import {gameControl} from '../common/ts/index'
import { hilog } from '@kit.PerformanceAnalysisKit';
import { harNAPI } from '@ohos/luaarkts';

export function UnitTest(context:CanvasRenderingContext2D, canvasWidth:number, canvasHeight:number, pathLuaMain:string){
    hilog.info(0x0000, 'testTag', '0.и§ҰеҸ‘harеҢ…initжҺҘеҸЈ');

    hilog.info(0x0000, 'testTag', '1.еҲқе§ӢеҢ–canvasзҺҜеўғ');
    gameControl.Instance = new gameControl(context, canvasWidth, canvasHeight)

    hilog.info(0x0000, 'testTag', '2.arkts->c++, жөӢиҜ•harеҢ…дёӯnapiжҺҘеҸЈеҸҠиҝ”еӣһеҖјTestHelloWorld');
    let strHello: string = harNAPI.TestHelloWorld("testTag, helloWorld");
    hilog.info(0x0000, 'testTag', '2.жөӢиҜ•harеҢ…дёӯnapiжҺҘеҸЈеҸҠиҝ”еӣһеҖј=%{public}s', strHello);

    hilog.info(0x0000, 'testTag', '3.еҲқе§ӢеҢ–luaзҺҜеўғ');
    harNAPI.InitLuaEnv(pathLuaMain);
    hilog.info(0x0000, 'testTag', '3.luaзҺҜеўғеҲқе§ӢеҢ–е®ҢжҲҗ');

    hilog.info(0x0000, 'testTag', '4.arkts->lua,жөӢиҜ•еҮҪж•°и°ғз”ЁtestLuaHelloWorld');
    harNAPI.T2lCallFunction("testLuaHelloWorld");

    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lSetVarInt');
    harNAPI.T2lSetVarInt("testValInt", 12);
    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lGetVarInt,иҺ·еҸ–luaдёӯtestValIntеҖј');
    let tmpValInt: number = harNAPI.T2lGetVarInt("testValInt");
    hilog.info(0x0000, 'testTag', '5.1иҝ”еӣһеҖј =%{public}d', tmpValInt);

    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lSetVarLong');
    harNAPI.T2lSetVarLong("testValLong", 1234567890);
    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lGetVarLong,иҺ·еҸ–luaдёӯtestValLongеҖј');
    let tmpValLong: number = harNAPI.T2lGetVarLong("testValLong");
    hilog.info(0x0000, 'testTag', '5.2иҝ”еӣһеҖј =%{public}d', tmpValLong);

    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lSetVarDouble');
    harNAPI.T2lSetVarDouble("testValDouble", 3.13456);
    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lGetVarDouble,иҺ·еҸ–luaдёӯtestValDoubleеҖј');
    let tmpValDouble: number = harNAPI.T2lGetVarDouble("testValDouble");
    console.info(`testTag, 5.3иҝ”еӣһеҖј =${tmpValDouble}`);

    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lSetVarChar');
    harNAPI.T2lSetVarChar("testValChar", "hello world123");
    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lGetVarChar,иҺ·еҸ–luaдёӯtestValCharеҖј');
    let tmpValChar: number = harNAPI.T2lGetVarChar("testValChar");
    hilog.info(0x0000, 'testTag', '5.4иҝ”еӣһеҖј =%{public}s', tmpValChar);

    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lSetVarBool');
    harNAPI.T2lSetVarBool("testValBool", false);
    hilog.info(0x0000, 'testTag', '5.arkts->lua,start t2lGetVarBool,иҺ·еҸ–luaдёӯtestValBoolеҖј');
    let tmpValBool: number = harNAPI.T2lGetVarBool("testValBool");
    hilog.info(0x0000, 'testTag', '5.5иҝ”еӣһеҖј =%{public}d', tmpValBool);

    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lSetTableInt');
    harNAPI.T2lSetTableInt("tbl", "id", 666);
    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lGetTableInt,иҺ·еҸ–luaдёӯTableдёӯзҡ„intеҸҳйҮҸ');
    tmpValInt = harNAPI.T2lGetTableInt("tbl", "id");
    hilog.info(0x0000, 'testTag', '6.1 иҝ”еӣһеҖј=%{public}d', tmpValInt);

    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lSetTableLong');
    harNAPI.T2lSetTableLong("tbl1", "idlong", 2200000001);
    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lGetTableLong,иҺ·еҸ–luaдёӯTableдёӯзҡ„longеһӢеҸҳйҮҸ');
    tmpValLong = harNAPI.T2lGetTableLong("tbl1", "idlong");
    hilog.info(0x0000, 'testTag', '6.2 иҝ”еӣһеҖј=%{public}d', tmpValLong);

    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lSetTableDouble');
    harNAPI.T2lSetTableDouble("tbl2", "id2", 123.123456);
    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lGetTableDouble,иҺ·еҸ–luaдёӯTableдёӯзҡ„doubleеһӢеҸҳйҮҸ');
    tmpValDouble = harNAPI.T2lGetTableDouble("tbl2", "id2");
    console.info(`testTag, 6.3иҝ”еӣһеҖј =${tmpValDouble}`);

    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lSetTableString');
    harNAPI.T2lSetTableString("tbl2", "str", "hello world123456789");
    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lGetTableChar,иҺ·еҸ–luaдёӯTableдёӯзҡ„charеһӢеҸҳйҮҸ');
    tmpValChar = harNAPI.T2lGetTableChar("tbl2", "str");
    hilog.info(0x0000, 'testTag', '6.4иҝ”еӣһеҖј =%{public}s', tmpValChar);

    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lSetTableBool');
    harNAPI.T2lSetTableBool("tbl2", "valueBool", false);
    hilog.info(0x0000, 'testTag', '6.arkts->lua,start t2lGetTableBool,иҺ·еҸ–luaдёӯTableдёӯзҡ„boolеһӢеҸҳйҮҸ');
    tmpValBool = harNAPI.T2lGetTableBool("tbl2", "valueBool");
    hilog.info(0x0000, 'testTag', '6.5иҝ”еӣһеҖј =%{public}d', tmpValBool);

    hilog.info(0x0000, 'testTag', '7жөӢиҜ•еӨҡжЁЎеқ—иҫ“еҮә =%{public}d', harNAPI.TestNAPI(1,2));

    hilog.info(0x0000, 'testTag', '8.жөӢиҜ•arkts->luaжҺҘеҸЈ,ж— иҝ”еӣһеҖј');
    harNAPI.T2lCallFunction("testLuaHelloWorld");

    hilog.info(0x0000, 'testTag', '8.жөӢиҜ•arkts->luaжҺҘеҸЈ,дј е…Ҙ numberпјҢиҝ”еӣһnumber');
    let res: number = harNAPI.T2lCallFunction("testcallback", 100, 200);
    hilog.info(0x0000, 'testTag', '8.иҝ”еӣһеҖј = ' + res);

    hilog.info(0x0000, 'testTag', '9.жөӢиҜ•arkts->luaжҺҘеҸЈ,дј е…Ҙ stringпјҢиҝ”еӣһstring');
    let res1: string = harNAPI.T2lCallFunction("testcallstring", "100", "200");
    hilog.info(0x0000, 'testTag', '9.иҝ”еӣһеҖј = ' + res1);

    hilog.info(0x0000, 'testTag', '10.жөӢиҜ•arkts->luaжҺҘеҸЈ,дј е…Ҙ booleanпјҢиҝ”еӣһboolean');
    let res2: boolean = harNAPI.T2lCallFunction("testcallbool", true);
    hilog.info(0x0000, 'testTag', '10.иҝ”еӣһеҖј = ' + res2);

    hilog.info(0x0000, 'testTag', '10.жөӢиҜ•arkts->luaжҺҘеҸЈ,дј е…Ҙ booleanпјҢиҝ”еӣһboolean');
    res2 = harNAPI.T2lCallFunction("testcallbool", false);
    hilog.info(0x0000, 'testTag', '10.иҝ”еӣһеҖј = ' + res2);
}